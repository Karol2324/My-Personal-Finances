<?xml version="1.0" encoding="utf-8"?>
<!--
    Diseño de cada fila del RecyclerView.
    Muestra: indicador visual de color, concepto, tipo, monto y acciones editar/eliminar.
    ViewBinding generará: ItemTransaccionBinding
-->
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="12dp"
    android:layout_marginVertical="6dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="8dp"
    app:cardElevation="2dp"
    app:strokeColor="@color/borde_tarjeta"
    app:strokeWidth="1dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="12dp">

        <!-- Barra vertical de color: verde = Ingreso, rojo = Gasto (se asigna en el Adapter) -->
        <View
            android:id="@+id/viewIndicadorTipo"
            android:layout_width="4dp"
            android:layout_height="0dp"
            android:background="@color/verde_ingreso"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Concepto de la transacción -->
        <TextView
            android:id="@+id/tvConcepto"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="8dp"
            android:ellipsize="end"
            android:maxLines="1"
            android:textColor="@color/texto_principal"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnEditar"
            app:layout_constraintStart_toEndOf="@id/viewIndicadorTipo"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="Supermercado" />

        <!-- Etiqueta visual del tipo: Ingreso o Gasto -->
        <TextView
            android:id="@+id/tvTipo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:layout_marginTop="4dp"
            android:paddingHorizontal="8dp"
            android:paddingVertical="2dp"
            android:textSize="12sp"
            app:layout_constraintStart_toEndOf="@id/viewIndicadorTipo"
            app:layout_constraintTop_toBottomOf="@id/tvConcepto"
            tools:background="@drawable/bg_badge_gasto"
            tools:text="Gasto"
            tools:textColor="@color/rojo_gasto" />

        <!-- Monto formateado; color según tipo (se asigna en el Adapter) -->
        <TextView
            android:id="@+id/tvMonto"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/rojo_gasto"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toStartOf="@id/btnEditar"
            app:layout_constraintTop_toTopOf="parent"
            tools:text="$ 45.50" />

        <!-- Botón editar: abrirá FormularioActivity en modo edición -->
        <ImageButton
            android:id="@+id/btnEditar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/editar_transaccion"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_edit"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toStartOf="@id/btnEliminar"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Botón eliminar: disparará confirmación y borrado en BD -->
        <ImageButton
            android:id="@+id/btnEliminar"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="@string/eliminar_transaccion"
            android:padding="8dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_delete"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>
